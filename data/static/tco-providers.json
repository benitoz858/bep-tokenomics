    "components": ["gpu", "storage", "networking", "controlPlane", "support", "goodput", "setup", "debugging"],
    "goodputFormula": "G_restart = {[(t_id + t_chkpt/2) + t_init] × j_size + t_repair × b_radius} × #failures × $/GPU-hr",
    "goodputVariables": {
      "t_id": "time to identify failure (minutes)",
      "t_chkpt": "checkpoint frequency (minutes)",
      "t_init": "job initialization time (minutes)",
      "t_repair": "time to repair/replace node (minutes)",
      "t_failover": "time to failover to hot spare (minutes)",
      "b_radius": "blast radius (GPUs per failure event, e.g. 8 for HGX, 64 for NVL72)",
      "j_size": "average job size in GPUs",
      "mtbf": "GPU-level Mean Time Between Failures (GPU-hours)"
    }
